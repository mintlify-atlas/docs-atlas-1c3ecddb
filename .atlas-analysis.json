  "keyFeatures": [
    "AI-powered Hinglish order extraction using Claude 3.5 Sonnet",
    "Distributed architecture with BullMQ queue system and horizontal scaling",
    "GST-compliant invoice generation with one-click PDF export",
    "Multi-tenant SaaS with organization-based access control",
    "Real-time job tracking with SSE streaming and correlation IDs",
    "Security-first design with rate limiting, PII redaction, and input sanitization"
  ],
  "publicApiSurface": [
    "POST /api/extract - Extract order from single message (sync)",
    "POST /api/extract-order - Extract order from chat history (sync)",
    "POST /api/async/extract - Queue single message extraction",
    "POST /api/async/extract-order - Queue chat log extraction",
    "POST /api/generate-invoice - Generate GST-compliant PDF invoice",
    "GET /api/orders - List all orders with pagination",
    "GET /api/orders/:id - Get specific order details",
    "PATCH /api/orders/:id - Update order status",
    "DELETE /api/orders/:id - Soft delete an order",
    "GET /api/jobs/:id - Check background job status",
    "GET /api/jobs/:id/stream - Real-time SSE job status streaming",
    "GET /api/queue/health - Queue metrics and health status",
    "GET /api/health - System health check (DB, Redis, AI)",
    "GET /api/stats - Organization statistics",
    "GET /api/admin/dlq - List failed jobs in dead letter queue",
    "POST /api/admin/dlq/:jobId/retry - Retry specific failed job",
    "POST /api/admin/dlq/retry-all - Retry all failed jobs"
  ]
}
